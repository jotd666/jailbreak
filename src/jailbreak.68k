level_completed_flag_9f = 0x9f
current_player_variables_1590 = 0x1590
* stage number 97 is the real stage number (can go beyond 5 when game wraps)
stage_number_97 = 0x97

start_8000:
	move.w	#0x1000,d2                      	| [$8000: ldx    #$1000]
	moveq	#0,d0                            	| [$8003: clra]
	moveq	#0,d1                            	| [$8004: clrb]
l_8005:
	 |  [$8005: sta    watchdog_3300]
	GET_REG_ADDRESS	0,d2                   	| [$8008: std    ,x++]
	addq.w	#2,d2                           	| [...]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	cmp.w	#0x1700,d2                       	| [$800a: cmpx   #$1700]
	jcs	l_8005                             	| [$800d: bcs    $8005]
	move.w	#0x11c0,d2                      	| [$800f: ldx    #$11c0]
l_8012:
	 |  [$8012: sta    watchdog_3300]
	GET_REG_ADDRESS	0,d2                   	| [$8015: std    ,x++]
	addq.w	#2,d2                           	| [...]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	cmp.w	#0x17a0,d2                       	| [$8017: cmpx   #$17a0]
	jcs	l_8012                             	| [$801a: bcs    $8012]
	jbsr	l_82aa                            	| [$801c: jsr    $82aa]
* init event queue: no events pending, all events acked
	move.w	#0x14c0,d2                      	| [$801f: ldx    #$14c0]
	GET_DP_ADDRESS	queue_event_pointer_3a  	| [$8022: stx    queue_event_pointer_3a]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	GET_DP_ADDRESS	queue_event_pointer_3c  	| [$8024: stx    queue_event_pointer_3c]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	move.b	#0xff,d0                        	| [$8026: ldd    #$ffff]
	move.w	#0xffff,d1                      	| [$8026: ldd    #$ffff]
l_8029:
	MAKE_D                                 	| [...]
	GET_REG_ADDRESS	0,d2                   	| [$8029: std    ,x++]
	addq.w	#2,d2                           	| [...]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	cmp.w	#0x1500,d2                       	| [$802b: cmpx   #$1500]
	jcs	l_8029                             	| [$802e: bcs    $8029]
	GET_DP_ADDRESS	0x3e                    	| [$8030: stx    $3e]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	GET_DP_ADDRESS	0x40                    	| [$8032: stx    $40]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	GET_ADDRESS	0x16ca                     	| [$8034: clr    $16ca]
	clr.b	(a0)                         	| [...]
	GET_ADDRESS	0x16cb                     	| [$8037: clr    $16cb]
	clr.b	(a0)                         	| [...]
	jbsr	l_80c2                            	| [$803a: jsr    $80c2]
	jbsr	l_80b5                            	| [$803d: jsr    $80b5]
	OP_1_ON_DP_ADDRESS	tst,game_state_25    | [$8040: tst    game_state_25]
	jeq	l_8050                             	| [$8042: beq    $8050]
	move.w	#0x14c0,d2                      	| [$8044: ldx    #$14c0]
	GET_DP_ADDRESS	queue_event_pointer_3a  	| [$8047: stx    queue_event_pointer_3a]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	move.b	#0xff,d0                        	| [$8049: ldd    #$ffff]
	move.w	#0xffff,d1                      	| [$8049: ldd    #$ffff]
	MAKE_D                                 	| [...]
	GET_REG_ADDRESS	0,d2                   	| [$804c: std    ,x]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
	MAKE_D                                 	| [...]
	GET_REG_ADDRESS	0x2,d2                 	| [$804e: std    $2,x]
	MOVE_W_FROM_REG	d1,a0                         	| [...]
l_8050:
	GET_ADDRESS	0x16c0                     	| [$8050: lda    $16c0]
	move.b	(a0),d0                         	| [...]
	jbsr	l_8902                            	| [$8053: jsr    $8902]
	 |  [$8056: sta    watchdog_3300]
	jbsr	l_b148                            	| [$8059: jsr    $b148]
	 |  [$805c: sta    watchdog_3300]
	move.b	#0x42,d0                        	| [$805f: lda    #$42]
	eor.b	#0x80,d0                         	| [$8061: eora   #$80]
	OP_W_ON_DP_ADDRESS	move,0x22,d0         | [$8063: sta    $22]
	GET_ADDRESS	nop_2043                   	| [$8065: sta    nop_2043]
	move.b	d0,(a0)                         	| [...]
	move.b	#0x03,d1                        	| [$8068: ldb    #$03]
	GET_DP_ADDRESS	0x21                    	| [$806a: eorb   $21]
	move.b	(a0),d6	| [...]
	eor.b	d6,d1                          	| [...]
	OP_W_ON_DP_ADDRESS	move,0x21,d1         | [$806c: stb    $21]
* enable interrupts, let the game run
	GET_ADDRESS	ctrl_2044                  	| [$806e: stb    ctrl_2044]
	move.b	d1,(a0)                         	| [...]
	CLR_I_FLAG                             	| [$8071: andcc  #$ef]
* poll event queue
event_loop_poll_8073:
	GET_DP_ADDRESS	queue_event_pointer_3c  	| [$8073: ldx    queue_event_pointer_3c]
	MOVE_W_TO_REG	a0,d2                         	| [...]
	GET_REG_ADDRESS	0,d2                   	| [$8075: ldd    ,x]
	LOAD_D                                 	| [$8075: ldd    ,x]
	asl.b	#1,d0                            	| [$8077: asla]
	jcs	event_loop_poll_8073               	| [$8078: bcs    event_loop_poll_8073]
* ack event
	and.b	#0x7f,d0                         	| [$807a: anda   #$7f]
	move.w	#0xffff,d3                      	| [$807c: ldy    #$ffff]
	GET_REG_ADDRESS	0,d2                   	| [$8080: sty    ,x++]
	addq.w	#2,d2                           	| [...]
	MOVE_W_FROM_REG	d3,a0                         	| [...]
	cmp.w	#0x14ff,d2                       	| [$8083: cmpx   #$14ff]
	jls	l_808b                             	| [$8086: bls    $808b]
	move.w	#0x14c0,d2                      	| [$8088: ldx    #$14c0]
l_808b:
	GET_DP_ADDRESS	queue_event_pointer_3c  	| [$808b: stx    queue_event_pointer_3c]
	MOVE_W_FROM_REG	d2,a0                         	| [...]
	
	.ifndef	RELEASE
	move.w	#0xbd14,d2
	.endif
	lea	event_table_bd14,a2            	| [$808d: ldx    #event_table_bd14]
	pea	event_loop_poll_8073 |  [$8090: ldy    #$8073] return to event_loop_poll_8073
	 |  [$8094: pshs   y]
	JMP_A_INDEXED	A2,6                   	| [$8096: jmp    [a,x]] [jump_table]

